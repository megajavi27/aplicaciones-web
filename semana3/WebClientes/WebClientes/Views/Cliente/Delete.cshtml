@model WebClientes.Models.ClienteModel

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="max-w-xl mx-auto py-4">
    <!-- Header/Back Navigation -->
    <div class="flex items-center space-x-4 mb-6">
        <a asp-action="Index" class="inline-flex items-center justify-center h-10 w-10 bg-white border border-slate-200 text-slate-500 hover:text-slate-800 rounded-full shadow-sm hover:shadow hover:-translate-x-0.5 transition duration-200" title="Volver al Listado">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-slate-900 to-indigo-900 bg-clip-text text-transparent">
                Eliminar Cliente
            </h1>
            <p class="text-slate-500 text-xs">Confirma la eliminación permanente del registro.</p>
        </div>
    </div>

    <!-- Confirmation Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200/80 overflow-hidden">
        <!-- Warning Banner -->
        <div class="bg-red-500 px-6 py-6 text-white flex items-start space-x-4">
            <div class="h-12 w-12 bg-white/10 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <div>
                <h3 class="font-extrabold text-lg">¿Confirmar Eliminación?</h3>
                <p class="text-red-100 text-xs mt-0.5">Esta acción no se puede deshacer. Los datos del cliente se borrarán por completo de la base de datos.</p>
            </div>
        </div>

        <!-- Info Summary -->
        <div class="p-6 md:p-8 space-y-6">
            <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-5 space-y-4">
                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Nombre Completo</span>
                    <span class="text-sm font-extrabold text-slate-800 mt-0.5 block">@Model.Nombre @Model.Apellidos</span>
                </div>
                
                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Identificación</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@Model.Identificacion</span>
                </div>

                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Tipo de Identificación</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@Model.TipoIdentificacion?.Descripcion</span>
                </div>

                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Género</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@Model.Genero?.Descripcion</span>
                </div>

                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Fecha de Nacimiento</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Estado Civil</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@Model.EstadoCivil?.Descripcion</span>
                </div>
                
                <div class="border-b border-slate-200/60 pb-3">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Teléfono</span>
                    <span class="text-sm font-semibold font-mono text-slate-700 mt-0.5 block">@Model.Telefono</span>
                </div>
                
                <div class="pt-1">
                    <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Correo Electrónico</span>
                    <span class="text-sm font-semibold text-slate-700 mt-0.5 block">@(string.IsNullOrEmpty(Model.Correo) ? "No especificado" : Model.Correo)</span>
                </div>
            </div>

            <!-- Delete Form -->
            <form asp-action="Delete">
                <input type="hidden" asp-for="ccliente" />
                <div class="space-y-3">
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3.5 px-6 rounded-xl shadow-lg shadow-red-500/20 hover:-translate-y-0.5 transition duration-300">
                        Sí, Eliminar Registro
                    </button>
                    <a asp-action="Index" class="inline-flex items-center justify-center w-full py-3.5 text-sm font-bold text-slate-500 hover:text-slate-800 hover:bg-slate-50 rounded-xl border border-slate-200 transition duration-200">
                        Cancelar y Conservar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
