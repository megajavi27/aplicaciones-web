@model EvaluacionParcial1.Models.Estudiante
@{ ViewData["Title"] = "Editar Estudiante"; }

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-slate-800">Editar Estudiante</h1>
        <p class="text-slate-500">Modifica los datos del alumno</p>
    </div>

    <div class="bg-white shadow-sm rounded-xl border border-slate-200 p-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            <input type="hidden" asp-for="EstudianteId" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label asp-for="Nombre" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="Nombre" class="w-full border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 px-4 py-2 border" />
                    <span asp-validation-for="Nombre" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Apellido" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="Apellido" class="w-full border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 px-4 py-2 border" />
                    <span asp-validation-for="Apellido" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div>
                    <label asp-for="FechaNacimiento" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="FechaNacimiento" type="date" class="w-full border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 px-4 py-2 border" />
                    <span asp-validation-for="FechaNacimiento" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Grado" class="block text-sm font-medium text-slate-700 mb-2"></label>
                    <input asp-for="Grado" class="w-full border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 px-4 py-2 border" />
                    <span asp-validation-for="Grado" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg shadow-sm transition duration-200">
                    <i class="bi bi-save me-2"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 px-6 rounded-lg transition duration-200">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
