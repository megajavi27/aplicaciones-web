<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Escolar</title>
    <script type="importmap"></script>
    <script src="https://unpkg.com/@@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-slate-50 text-slate-800 font-['Plus_Jakarta_Sans',sans-serif] min-h-screen flex flex-col">

    <header class="sticky top-0 z-50">
        <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200/80 shadow-sm py-3">
            <div class="container mx-auto px-6 flex items-center justify-between">
                <a class="flex items-center space-x-2 text-xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill text-blue-600 text-2xl"></i>
                    <span>Sistema Escolar</span>
                </a>
                <div class="flex items-center space-x-1">
                    <a class="flex items-center space-x-1 py-2 px-4 rounded-full text-slate-600 hover:text-blue-600 hover:bg-blue-50 transition duration-200 font-medium text-sm"
                       asp-controller="Estudiante" asp-action="Index">
                        <i class="bi bi-people-fill"></i><span>Estudiantes</span>
                    </a>
                    <a class="flex items-center space-x-1 py-2 px-4 rounded-full text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition duration-200 font-medium text-sm"
                       asp-controller="Profesor" asp-action="Index">
                        <i class="bi bi-person-video3"></i><span>Profesores</span>
                    </a>
                    <a class="flex items-center space-x-1 py-2 px-4 rounded-full text-slate-600 hover:text-violet-600 hover:bg-violet-50 transition duration-200 font-medium text-sm"
                       asp-controller="Clase" asp-action="Index">
                        <i class="bi bi-journal-bookmark-fill"></i><span>Clases</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow container mx-auto px-6 py-8">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-slate-200 py-4 mt-auto">
        <div class="container mx-auto px-6 text-center text-slate-500 text-sm">
            &copy; 2026 - <span class="font-semibold text-slate-700">Sistema de Gestión Escolar</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
