@model WebClientes.Models.ClienteModel

@{
    ViewData["Title"] = "Nuevo Cliente";
}

<div class="max-w-xl mx-auto py-4">
    <!-- Header/Back Navigation -->
    <div class="flex items-center space-x-4 mb-6">
        <a asp-action="Index" class="inline-flex items-center justify-center h-10 w-10 bg-white border border-slate-200 text-slate-500 hover:text-slate-800 rounded-full shadow-sm hover:shadow hover:-translate-x-0.5 transition duration-200" title="Volver al Listado">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-slate-900 to-indigo-900 bg-clip-text text-transparent">
                Agregar Cliente
            </h1>
            <p class="text-slate-500 text-xs">Ingresa los datos para registrar un nuevo cliente.</p>
        </div>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200/80 p-6 md:p-8">
        <h3 class="text-lg font-bold text-slate-800 border-b border-slate-100 pb-4 mb-6">Información General</h3>

        <form asp-action="Create" autocomplete="off" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-4 rounded-xl bg-red-50 border border-red-100 text-red-700 text-sm" role="alert"></div>

            <div class="space-y-1.5">
                <label asp-for="Nombres_Cliente" class="block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Nombres_Cliente" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition duration-200 text-sm text-slate-800 placeholder-slate-400" placeholder="Ej. Luis Antonio" required />
                <span asp-validation-for="Nombres_Cliente" class="text-xs font-medium text-red-500 mt-1 block"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Apellidos" class="block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Apellidos" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition duration-200 text-sm text-slate-800 placeholder-slate-400" placeholder="Ej. Llerena Ocaña" required />
                <span asp-validation-for="Apellidos" class="text-xs font-medium text-red-500 mt-1 block"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Direccion" class="block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Direccion" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition duration-200 text-sm text-slate-800 placeholder-slate-400" placeholder="Ej. Av. Cevallos y Espejo, Ambato" required />
                <span asp-validation-for="Direccion" class="text-xs font-medium text-red-500 mt-1 block"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Telefono" class="block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Telefono" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition duration-200 text-sm text-slate-800 placeholder-slate-400" placeholder="Ej. 0987654321" required />
                <span asp-validation-for="Telefono" class="text-xs font-medium text-red-500 mt-1 block"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Correo" class="block text-sm font-semibold text-slate-700"></label>
                <input asp-for="Correo" type="email" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition duration-200 text-sm text-slate-800 placeholder-slate-400" placeholder="Ej. lleroc1@gmail.com" />
                <span asp-validation-for="Correo" class="text-xs font-medium text-red-500 mt-1 block"></span>
            </div>

            <div class="pt-4 space-y-3">
                <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-3.5 px-6 rounded-xl shadow-lg shadow-blue-500/20 hover:shadow-blue-500/35 hover:-translate-y-0.5 transition duration-300">
                    Guardar Registro
                </button>
                <a asp-action="Index" class="inline-flex items-center justify-center w-full py-3 text-sm font-bold text-slate-500 hover:text-slate-800 hover:bg-slate-50 rounded-xl border border-slate-200 transition duration-200">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
