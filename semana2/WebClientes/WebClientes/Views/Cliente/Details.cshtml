@model WebClientes.Models.ClienteModel

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="max-w-xl mx-auto py-4">
    <!-- Header/Back Navigation -->
    <div class="flex items-center space-x-4 mb-6">
        <a asp-action="Index" class="inline-flex items-center justify-center h-10 w-10 bg-white border border-slate-200 text-slate-500 hover:text-slate-800 rounded-full shadow-sm hover:shadow hover:-translate-x-0.5 transition duration-200" title="Volver al Listado">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-slate-900 to-indigo-900 bg-clip-text text-transparent">
                Detalles del Cliente
            </h1>
            <p class="text-slate-500 text-xs font-medium">Información detallada del cliente seleccionado.</p>
        </div>
    </div>

    <!-- Profile Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200/80 overflow-hidden">
        <!-- Card Header (Gradient & Initials Avatar) -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-10 flex flex-col items-center justify-center text-center">
            <div class="rounded-full h-20 w-20 bg-white/10 backdrop-blur-md border border-white/20 text-white flex items-center justify-center text-3xl font-extrabold shadow-inner mb-4">
                @(Model.Nombres_Cliente?.Length > 0 ? Model.Nombres_Cliente[0].ToString() : "C")@(Model.Apellidos?.Length > 0 ? Model.Apellidos[0].ToString() : "")
            </div>
            <h2 class="text-white text-xl font-bold">@Model.Nombres_Cliente @Model.Apellidos</h2>
            <span class="text-blue-100 text-xs font-semibold mt-1 tracking-wide">ID de Registro: #@Model.id</span>
        </div>

        <!-- Card Body (Details Fields) -->
        <div class="p-6 md:p-8 space-y-6 bg-white">
            <div class="grid grid-cols-1 gap-6">
                <!-- Nombres -->
                <div class="flex items-start space-x-4 border-b border-slate-100 pb-4">
                    <div class="h-10 w-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Nombre Completo</span>
                        <span class="text-base text-slate-800 font-bold mt-0.5 block">@Model.Nombres_Cliente @Model.Apellidos</span>
                    </div>
                </div>

                <!-- Dirección -->
                <div class="flex items-start space-x-4 border-b border-slate-100 pb-4">
                    <div class="h-10 w-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Dirección de Contacto</span>
                        <span class="text-base text-slate-700 font-medium mt-0.5 block">@Model.Direccion</span>
                    </div>
                </div>

                <!-- Teléfono -->
                <div class="flex items-start space-x-4 border-b border-slate-100 pb-4">
                    <div class="h-10 w-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3l2 4H8a1 1 0 00-1 1v4a1 1 0 001 1h3l2 4h-3a2 2 0 01-2-2v-3H5a2 2 0 01-2-2V5z" />
                        </svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Teléfono</span>
                        <span class="text-base text-slate-700 font-mono font-medium mt-0.5 block">@Model.Telefono</span>
                    </div>
                </div>

                <!-- Correo -->
                <div class="flex items-start space-x-4">
                    <div class="h-10 w-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Correo Electrónico</span>
                        @if (string.IsNullOrEmpty(Model.Correo))
                        {
                            <span class="text-sm text-slate-400 italic mt-0.5 block">No especificado</span>
                        }
                        else
                        {
                            <a href="mailto:@Model.Correo" class="text-base text-blue-600 hover:text-blue-800 hover:underline font-bold mt-0.5 block">@Model.Correo</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Footer (Actions) -->
        <div class="px-6 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-end gap-3">
            <a asp-action="Edit" asp-route-id="@Model.id" class="w-full sm:w-auto inline-flex items-center justify-center bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm px-6 py-3 rounded-full shadow-md shadow-amber-500/20 hover:-translate-y-0.5 transition duration-300">
                Editar Perfil
            </a>
            <a asp-action="Index" class="w-full sm:w-auto inline-flex items-center justify-center bg-white border border-slate-200 text-slate-600 hover:text-slate-800 hover:bg-slate-50 font-bold text-sm px-6 py-3 rounded-full transition duration-200">
                Volver al Listado
            </a>
        </div>
    </div>
</div>
