@model IEnumerable<WebClientes.Models.ClienteModel>

@{
    ViewData["Title"] = "Listado de Clientes";
}

<div class="max-w-6xl mx-auto space-y-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 pb-5 border-b border-slate-200">
        <div>
            <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-slate-900 via-blue-800 to-indigo-900 bg-clip-text text-transparent flex items-center gap-2">
                <i class="bi bi-people-fill text-blue-600"></i> Listado de Clientes
            </h1>
            <p class="text-slate-500 text-sm mt-1">Administra y organiza toda la información y contactos de tus clientes registrados.</p>
        </div>
        <a asp-action="Create" class="inline-flex items-center justify-center space-x-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold text-sm px-5 py-3 rounded-full shadow-lg shadow-blue-500/20 hover:shadow-blue-500/30 hover:-translate-y-0.5 transition duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            <span>Nuevo Cliente</span>
        </a>
    </div>

    <!-- Table Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200/80 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <h3 class="font-bold text-slate-700 text-base">Registros Activos</h3>
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100/50">
                Total: @Model.Count()
            </span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/80 border-b border-slate-100 text-slate-500 text-xs font-semibold uppercase tracking-wider">
                        <th class="py-4 px-6">Nombres del Cliente</th>
                        <th class="py-4 px-6">Apellidos</th>
                        <th class="py-4 px-6">Dirección</th>
                        <th class="py-4 px-6">Teléfono</th>
                        <th class="py-4 px-6">Correo</th>
                        <th class="py-4 px-6 text-center" style="width: 180px;">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-16 text-slate-400">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <div class="h-16 w-16 bg-slate-100 text-slate-400 rounded-full flex items-center justify-center">
                                        <i class="bi bi-people text-3xl"></i>
                                    </div>
                                    <h4 class="font-bold text-slate-700 text-lg">No hay clientes agregados</h4>
                                    <p class="text-slate-400 text-sm max-w-xs">Comienza ingresando un nuevo cliente usando el botón de la esquina superior.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50/40 transition duration-200">
                                <td class="py-4 px-6 font-semibold text-slate-900">
                                    @Html.DisplayFor(modelItem => item.Nombres_Cliente)
                                </td>
                                <td class="py-4 px-6 text-slate-700">
                                    @Html.DisplayFor(modelItem => item.Apellidos)
                                </td>
                                <td class="py-4 px-6 text-slate-500 text-sm">
                                    @Html.DisplayFor(modelItem => item.Direccion)
                                </td>
                                <td class="py-4 px-6 text-slate-500 font-mono text-sm">
                                    @Html.DisplayFor(modelItem => item.Telefono)
                                </td>
                                <td class="py-4 px-6">
                                    <a href="mailto:@item.Correo" class="text-blue-600 hover:text-blue-800 hover:underline text-sm font-medium">
                                        @Html.DisplayFor(modelItem => item.Correo)
                                    </a>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <div class="inline-flex rounded-lg shadow-sm border border-slate-200 overflow-hidden bg-white">
                                        <a asp-action="Edit" asp-route-id="@item.id" class="p-2.5 text-amber-500 hover:bg-amber-50 border-r border-slate-200 transition duration-150" title="Editar">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                            </svg>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.id" class="p-2.5 text-blue-500 hover:bg-blue-50 border-r border-slate-200 transition duration-150" title="Detalles">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.id" class="p-2.5 text-red-500 hover:bg-red-50 transition duration-150" title="Eliminar">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
